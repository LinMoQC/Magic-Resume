{
  "name": "@magic-resume/mcp",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "magic-resume": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@magic-resume/resume-schema": "workspace:*",
    "@magic-resume/resume-templates": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-json-patch": "^3.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5"
  }
}
