{
  "name": "@magic-resume/resume-templates",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./TemplateCustomizer": {
      "types": "./dist/TemplateCustomizer/index.d.ts",
      "default": "./dist/TemplateCustomizer/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./config/defaults": {
      "types": "./dist/config/defaults.d.ts",
      "default": "./dist/config/defaults.js"
    },
    "./config/magic-templates": {
      "types": "./dist/config/magic-templates.d.ts",
      "default": "./dist/config/magic-templates.js"
    },
    "./renderer/MagicResumeRenderer": {
      "types": "./dist/renderer/MagicResumeRenderer.d.ts",
      "default": "./dist/renderer/MagicResumeRenderer.js"
    },
    "./renderer/EditableCanvas": {
      "types": "./dist/renderer/EditableCanvas.d.ts",
      "default": "./dist/renderer/EditableCanvas.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "default": "./dist/registry.js"
    },
    "./types/magic-dsl": {
      "types": "./dist/types/magic-dsl.d.ts",
      "default": "./dist/types/magic-dsl.js"
    },
    "./types/resume": {
      "types": "./dist/types/resume.d.ts",
      "default": "./dist/types/resume.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run lint"
  },
  "dependencies": {
    "@magic-resume/resume-schema": "workspace:*",
    "dompurify": "^3.2.6",
    "lodash.get": "^4.4.2"
  },
  "peerDependencies": {
    "lucide-react": "^0.513.0",
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19",
    "react-i18next": "^15.5.2"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/lodash.get": "^4.4.9",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
