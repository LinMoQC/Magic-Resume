# ============================================================
# Magic Resume – Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in the values.

# ------ Deployment Mode -----------------------------------------------
# self-hosted : Pure local editor, no login required, no backend needed.
# cloud       : Clerk auth + NestJS backend + cloud sync (magic-resume.cn)
NEXT_PUBLIC_APP_MODE=self-hosted

# ------ App URL -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Cloud mode only -----------------------------------------------
# Required when NEXT_PUBLIC_APP_MODE=cloud

# Clerk (https://clerk.com)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...

# ------ Backend (single API address) ----------------------------------
# ONE origin for the whole backend — Magic-Core's edge gateway (apps/gateway),
# which routes by path prefix:
#   /api/(chat|graph|agent|pdf|translate|interview) → agent-service
#   everything else /api/                           → platform-api
# Dev: started by Magic-Core's `pnpm dev` on :3110 (defaults to it if unset).
# Prod: the public gateway origin (nginx terminates TLS in front).
# NEXT_PUBLIC_API_URL=http://localhost:3110

