# ============================================================
# Magic Resume – Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in the values.

# ------ Deployment Mode -----------------------------------------------
# self-hosted : Pure local editor, no login required, no backend needed.
# cloud       : Clerk auth + NestJS backend + cloud sync (magic-resume.cn)
NEXT_PUBLIC_APP_MODE=self-hosted

# ------ App URL -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Cloud mode only -----------------------------------------------
# Required when NEXT_PUBLIC_APP_MODE=cloud

# Clerk (https://clerk.com)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# NestJS Core backend
# NEXT_PUBLIC_CLOUD_API_URL=https://your-backend.com

# ------ AI / Agent backend (optional in self-hosted) ------------------
# Python agent server (interview, translate, AI optimize)
# BACKEND_URL=http://localhost:8000

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-...
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
