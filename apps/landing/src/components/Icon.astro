---
/**
 * Tiny inline-SVG icon set. Stroke-based, currentColor, 1.6 stroke — consistent
 * weight across the page. Add paths here as needed rather than pulling an icon lib.
 */
interface Props {
  name:
    | 'arrow-right'
    | 'github'
    | 'flask'
    | 'lock'
    | 'sparkle'
    | 'check'
    | 'star'
    | 'shield'
    | 'target'
    | 'languages'
    | 'mic'
    | 'download'
    | 'pen'
    | 'x'
    | 'zap'
    | 'arrow-up'
    | 'clipboard';
  class?: string;
  size?: number;
}
const { name, class: className, size = 20 } = Astro.props;
const p: Record<Props['name'], string> = {
  'arrow-right': '<path d="M5 12h14M13 6l6 6-6 6"/>',
  github:
    '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.2-1.5 6.2-6.8A5.3 5.3 0 0 0 19 4.8a5 5 0 0 0-.1-3.7s-1.2-.4-3.9 1.5a13.4 13.4 0 0 0-7 0C5.3.7 4.1 1.1 4.1 1.1A5 5 0 0 0 4 4.8 5.3 5.3 0 0 0 2.6 8.5c0 5.3 3.2 6.5 6.2 6.8a3.4 3.4 0 0 0-.9 2.6V22"/>',
  flask:
    '<path d="M9 3h6M10 3v6.5L5.2 17A2 2 0 0 0 7 20h10a2 2 0 0 0 1.8-3L14 9.5V3M8 14h8"/>',
  lock: '<rect x="4" y="10.5" width="16" height="10" rx="2"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/>',
  sparkle:
    '<path d="M12 3l1.6 5.4L19 10l-5.4 1.6L12 17l-1.6-5.4L5 10l5.4-1.6L12 3z"/>',
  check: '<path d="M4 12.5l5 5 11-11"/>',
  star: '<path d="M12 3l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 18l-5.9 3 1.2-6.5L2.5 9.9 9 9l3-6z"/>',
  shield: '<path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/>',
  target:
    '<circle cx="12" cy="12" r="8.5"/><circle cx="12" cy="12" r="4.5"/><circle cx="12" cy="12" r="0.6" fill="currentColor" stroke="none"/>',
  languages:
    '<path d="M3 6h9M7.5 4v2M10 6c0 4-3.5 7-7 8M5 9c0 2 2 3.5 5 4.5M13 20l4-9 4 9M14.5 17h5"/>',
  mic: '<rect x="9" y="3" width="6" height="11" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/>',
  download: '<path d="M12 3v11M7.5 10.5L12 15l4.5-4.5M4.5 20h15"/>',
  pen: '<path d="M14.5 4.5l5 5L8 21H3v-5L14.5 4.5zM12.5 6.5l5 5"/>',
  x: '<path d="M6 6l12 12M18 6L6 18"/>',
  zap: '<path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>',
  'arrow-up': '<path d="M12 19V5M6 11l6-6 6 6"/>',
  clipboard:
    '<rect x="5" y="4" width="14" height="17" rx="2"/><path d="M9 4a3 3 0 0 1 6 0M9 10h6M9 14h6"/>',
};
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={p[name]}
/>
