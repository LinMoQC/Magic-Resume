---
import type { Copy } from '@/i18n/ui';
import Icon from '@/components/Icon.astro';
import ProposalStream from '@/components/islands/ProposalStream';

interface Props {
  copy: Copy;
}
const { copy } = Astro.props;
const w = copy.workflow;
---

<section id="workflow" class="relative border-t border-hair py-24 md:py-32">
  <div class="mx-auto max-w-[1120px] px-5 md:px-6">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">{w.eyebrow}</p>
      <h2 class="mt-4 font-display text-[clamp(1.7rem,3.6vw,2.4rem)] font-semibold tracking-[-0.02em] text-ink">
        {w.title}
      </h2>
      <p class="mt-3 max-w-xl text-[15px] leading-relaxed text-muted md:text-base">
        {w.subtitle}
      </p>
    </div>

    <!-- live proposal stream + audit ledger -->
    <div class="reveal relative mt-12" style="--reveal-delay:1">
      <div class="linear-frame">
        <ProposalStream client:visible labels={w.stream} />
      </div>
    </div>

    <div class="reveal mt-8 flex flex-wrap gap-x-8 gap-y-3" style="--reveal-delay:2">
      {
        w.points.map((point) => (
          <div class="flex items-center gap-2.5 text-[14px] text-ink/90">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-sky-400/10 text-sky-400">
              <Icon name="check" size={12} />
            </span>
            {point}
          </div>
        ))
      }
    </div>
  </div>
</section>
