---
import type { Copy, Locale } from '@/i18n/ui';
import { APP_LINKS, GITHUB } from '@/consts';
import Icon from '@/components/Icon.astro';
import EditorMockup from '@/components/islands/EditorMockup';

interface Props {
  copy: Copy;
  locale: Locale;
}
const { copy, locale } = Astro.props;
const h = copy.hero;

// Split the headline so the accent phrase can be tinted sky (solid, not gradient).
const idx = h.titleAccent ? h.title.indexOf(h.titleAccent) : -1;
const pre = idx >= 0 ? h.title.slice(0, idx) : h.title;
const accent = idx >= 0 ? h.titleAccent : '';
const post = idx >= 0 ? h.title.slice(idx + h.titleAccent.length) : '';
---

<section id="top" class="relative overflow-hidden">
  <div class="hero-bloom pointer-events-none absolute inset-x-0 top-0 h-[640px]" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-[1400px] px-5 pt-40 md:px-6 md:pt-52 lg:pt-56">
    <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
      <h1
        class="reveal font-display text-[clamp(2.35rem,6vw,3.9rem)] font-semibold leading-[1.06] tracking-[-0.025em] text-ink"
        style="--reveal-delay:1"
      >
        {pre}<span class="text-sky-400">{accent}</span>{post}
      </h1>

      <p
        class="reveal mt-6 max-w-xl text-[16px] leading-relaxed text-muted md:text-[17px]"
        style="--reveal-delay:2"
      >
        {h.subtitle}
      </p>

      <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-3" style="--reveal-delay:3">
        <a
          href={APP_LINKS.dashboard}
          class="group flex items-center gap-2 rounded-lg bg-ink px-5 py-2.5 text-[14px] font-semibold text-workbench transition-opacity hover:opacity-85"
        >
          {h.ctaPrimary}
          <Icon name="arrow-right" size={16} class="transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href={GITHUB.repo}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 rounded-lg border border-hair bg-surface/50 px-5 py-2.5 text-[14px] font-medium text-muted transition-colors hover:text-ink"
        >
          <Icon name="github" size={16} />
          {h.ctaSecondary}
        </a>
      </div>

      <ul class="reveal mt-7 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-[13px] text-faint" style="--reveal-delay:4">
        {
          h.trust.map((t, i) => (
            <>
              {i > 0 && <li aria-hidden="true" class="h-3 w-px bg-hairline" />}
              <li class="flex items-center gap-1.5">
                <Icon name="check" size={13} class="text-sky-400" />
                {t}
              </li>
            </>
          ))
        }
      </ul>
    </div>

    <!-- Product frame: Linear-style hairlines without an extra backing plate. -->
    <div class="reveal relative mx-auto mt-16 max-w-[1280px] md:mt-20" style="--reveal-delay:3">
      <div class="linear-frame">
        <EditorMockup client:load labels={h.mockup} lang={locale} />
      </div>
    </div>
  </div>
</section>
